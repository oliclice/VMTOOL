/* Material Design 3 Theme
 * 基于 M3 Design Tokens：tonal surface、state layer、elevation
 * 参考：https://m3.material.io — Dynamic color, tactile surfaces
 */

/* ==================== 全局 ==================== */
QWidget {
    font-family: "Roboto", "Noto Sans SC", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 14px;
    color: @text_primary;
}

/* ==================== 主窗口 ==================== */
QMainWindow {
    background-color: @bg_primary;
}

/* ==================== 标签页 ==================== */
QTabWidget::pane {
    border: none;
    background-color: @bg_primary;
}

QTabBar {
    background-color: @bg_primary;
}

QTabBar::tab {
    background-color: transparent;
    color: @text_secondary;
    padding: 12px 16px;
    margin-right: 4px;
    border: none;
    border-bottom: 2px solid transparent;
    font-weight: 500;
}

QTabBar::tab:hover {
    color: @text_primary;
    background-color: @rgba_surface_hover;
}

QTabBar::tab:selected {
    color: @text_primary;
    border-bottom: 2px solid @accent;
    font-weight: 500;
}

/* ==================== 分组框 ==================== */
QGroupBox {
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_lg;
    margin-top: 16px;
    padding: 16px 12px 12px 12px;
    font-weight: 500;
    color: @text_primary;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 12px;
    padding: 0 6px;
    background-color: @bg_primary;
}

/* ==================== 按钮 ==================== */
/* 默认按钮 — Ghost 风格 */
QPushButton {
    background-color: transparent;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 10px 16px;
    font-weight: 500;
    min-height: 20px;
}

QPushButton:hover {
    background-color: @rgba_surface_hover;
    border-color: @rgba_border_strong;
}

QPushButton:pressed {
    background-color: @rgba_surface_pressed;
}

QPushButton:disabled {
    background-color: transparent;
    color: @text_disabled;
    border-color: @rgba_border_disabled;
}

/* 主要按钮 — M3 Primary */
QPushButton[cssClass="primary"],
QPushButton#exportButton,
QPushButton#importButton {
    background-color: @accent;
    color: @bg_primary;
    border: 1px solid @accent;
    font-weight: 500;
    border-radius: 20px;
}

QPushButton[cssClass="primary"]:hover,
QPushButton#exportButton:hover,
QPushButton#importButton:hover {
    background-color: @accent_hover;
    border-color: @accent_hover;
}

/* 危险按钮 */
QPushButton[cssClass="danger"] {
    background-color: @danger;
    color: @bg_primary;
    border: 1px solid @danger;
    border-radius: 20px;
}

QPushButton[cssClass="danger"]:hover {
    background-color: @danger_hover;
    border-color: @danger_hover;
}

/* ==================== 输入框 ==================== */
QLineEdit, QSpinBox, QDoubleSpinBox {
    background-color: #25232a;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 10px 14px;
    selection-background-color: @accent;
    selection-color: @bg_primary;
}

QLineEdit:focus, QSpinBox:focus, QDoubleSpinBox:focus {
    border: 2px solid @accent;
    outline: none;
}

QLineEdit:disabled, QSpinBox:disabled {
    background-color: @bg_disabled;
    color: @text_disabled;
    border-color: @rgba_border_disabled;
}

/* ==================== 下拉框 ==================== */
QComboBox {
    background-color: #25232a;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 10px 14px;
    min-width: 120px;
}

QComboBox:hover {
    border-color: @rgba_border_strong;
}

QComboBox:focus {
    border: 2px solid @accent;
}

QComboBox::drop-down {
    border: none;
    width: 24px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid @text_secondary;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background-color: @bg_elevated;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    selection-background-color: @rgba_surface_hover;
    selection-color: @text_primary;
    outline: none;
    padding: 4px;
}

/* ==================== 表格 ==================== */
QTableWidget, QTableView {
    background-color: @bg_elevated;
    color: @text_primary;
    border: 1px solid @rgba_border_subtle;
    border-radius: @radius_lg;
    gridline-color: @rgba_border_disabled;
    selection-background-color: @rgba_selection;
    selection-color: @text_primary;
    alternate-background-color: @rgba_surface;
}

QTableWidget::item, QTableView::item {
    padding: 8px 10px;
    border: none;
}

QTableWidget::item:selected, QTableView::item:selected {
    background-color: @rgba_selection;
}

QTableWidget::item:hover, QTableView::item:hover {
    background-color: @rgba_surface_hover;
}

QHeaderView::section {
    background-color: @bg_secondary;
    color: @text_secondary;
    border: none;
    border-bottom: 1px solid @rgba_border_subtle;
    border-right: 1px solid @rgba_border_disabled;
    padding: 10px 12px;
    font-weight: 500;
    font-size: 12px;
}

QHeaderView::section:last {
    border-right: none;
}

/* ==================== 滚动条 ==================== */
QScrollBar:vertical {
    background-color: transparent;
    width: 8px;
    margin: 0;
}

QScrollBar::handle:vertical {
    background-color: @border_default;
    border-radius: 4px;
    min-height: 30px;
}

QScrollBar::handle:vertical:hover {
    background-color: @border_hover;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background-color: transparent;
    height: 8px;
    margin: 0;
}

QScrollBar::handle:horizontal {
    background-color: @border_default;
    border-radius: 4px;
    min-width: 30px;
}

QScrollBar::handle:horizontal:hover {
    background-color: @border_hover;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ==================== 进度条 ==================== */
QProgressBar {
    background-color: @rgba_surface_disabled;
    border: none;
    border-radius: 4px;
    height: 8px;
    text-align: center;
    color: transparent;
}

QProgressBar::chunk {
    background-color: @accent;
    border-radius: 4px;
}

/* ==================== 复选框和单选按钮 ==================== */
QCheckBox, QRadioButton {
    color: @text_primary;
    spacing: 10px;
}

QCheckBox::indicator, QRadioButton::indicator {
    width: 18px;
    height: 18px;
    border: 1px solid @rgba_border_strong;
    border-radius: 2px;
    background-color: transparent;
}

QRadioButton::indicator {
    border-radius: 9px;
}

QCheckBox::indicator:hover, QRadioButton::indicator:hover {
    border-color: @accent;
}

QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background-color: @accent;
    border-color: @accent;
}

QCheckBox::indicator:checked {
    image: none;
    border: none;
    background-color: @accent;
}

/* ==================== 菜单 ==================== */
QMenuBar {
    background-color: @bg_primary;
    color: @text_primary;
    border-bottom: 1px solid @rgba_border_subtle;
    padding: 2px;
}

QMenuBar::item {
    padding: 8px 12px;
    border-radius: @radius_sm;
}

QMenuBar::item:selected {
    background-color: @rgba_surface_hover;
}

QMenu {
    background-color: @bg_elevated;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 4px;
}

QMenu::item {
    padding: 10px 24px 10px 12px;
    border-radius: @radius_sm;
}

QMenu::item:selected {
    background-color: @rgba_surface_hover;
}

QMenu::separator {
    height: 1px;
    background-color: @rgba_border_subtle;
    margin: 4px 8px;
}

/* ==================== 状态栏 ==================== */
QStatusBar {
    background-color: @bg_secondary;
    color: @text_secondary;
    border-top: 1px solid @rgba_border_subtle;
    padding: 6px 8px;
}

/* ==================== 工具提示 ==================== */
QToolTip {
    background-color: @bg_elevated;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 8px 12px;
    font-size: 13px;
}

/* ==================== 分割器 ==================== */
QSplitter::handle {
    background-color: @rgba_border_subtle;
}

QSplitter::handle:horizontal {
    width: 1px;
}

QSplitter::handle:vertical {
    height: 1px;
}

QSplitter::handle:hover {
    background-color: @accent;
}

/* ==================== 树形视图 ==================== */
QTreeWidget, QTreeView {
    background-color: @bg_elevated;
    color: @text_primary;
    border: 1px solid @rgba_border_subtle;
    border-radius: @radius_lg;
    outline: none;
}

QTreeWidget::item, QTreeView::item {
    padding: 8px 10px;
    border: none;
}

QTreeWidget::item:selected, QTreeView::item:selected {
    background-color: @rgba_selection;
}

QTreeWidget::item:hover, QTreeView::item:hover {
    background-color: @rgba_surface_hover;
}

QTreeWidget::branch, QTreeView::branch {
    background-color: transparent;
}

/* ==================== 文本编辑 ==================== */
QTextEdit, QPlainTextEdit {
    background-color: #25232a;
    color: @text_primary;
    border: 1px solid @rgba_border_standard;
    border-radius: @radius_md;
    padding: 10px;
    selection-background-color: @accent;
    selection-color: @bg_primary;
}

QTextEdit:focus, QPlainTextEdit:focus {
    border: 2px solid @accent;
}

/* ==================== 滚动区域 ==================== */
QScrollArea {
    border: none;
    background-color: transparent;
}

/* ==================== 标签 ==================== */
QLabel {
    color: @text_primary;
    background-color: transparent;
}

/* 次要文字 */
QLabel[cssClass="secondary"] {
    color: @text_secondary;
}

/* 成功状态 */
QLabel[cssClass="success"] {
    color: @success;
    font-weight: 500;
}

/* 错误状态 */
QLabel[cssClass="error"] {
    color: @danger;
    font-weight: 500;
}

/* 信息框 */
QLabel[cssClass="info"] {
    color: @accent;
    padding: 8px;
    background-color: @rgba_info_bg;
    border-radius: @radius_md;
}

/* ==================== 分隔线 ==================== */
QFrame[frameShape="4"],
QFrame[frameShape="5"] {
    background-color: @rgba_border_subtle;
    max-height: 1px;
}

/* ==================== 设置界面 ==================== */
#settings_sidebar {
    background-color: @bg_secondary;
    border-right: 1px solid @rgba_border_standard;
}

#settings_nav_list {
    border: none;
    background-color: transparent;
}

#settings_nav_list::item {
    padding: 12px 16px;
    border-left: 3px solid transparent;
    color: @text_primary;
}

#settings_nav_list::item:selected {
    background-color: @rgba_selection;
    border-left: 3px solid @accent;
}

#settings_nav_list::item:hover {
    background-color: @rgba_surface_hover;
}

/* ==================== 侧边栏导航 ==================== */
SidebarNav {
    background-color: @sidebar_bg;
}

NavItem {
    border-radius: @radius_md;
    padding: 0px;
}

NavItem:hover {
    background-color: @rgba_surface_hover;
}

NavItem[active="true"] {
    background-color: @rgba_selection;
}

NavItem QLabel {
    color: @sidebar_text;
}

NavItem[active="true"] QLabel {
    color: @sidebar_text_active;
}

GroupLabel {
    color: @nav_group_text;
}

/* ==================== 仪表盘 ==================== */
DashboardPage {
    background-color: @bg_primary;
}
